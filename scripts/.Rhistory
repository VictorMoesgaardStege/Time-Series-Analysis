rm(list = ls())
library(ggplot2)
library(patchwork)
# ---------------------------------------------------------------------------
# 0. Setup
# ---------------------------------------------------------------------------
set.seed(42)
for (dir_path in c("report/figures", "output/tables", "output/models")) {
if (!dir.exists(dir_path)) dir.create(dir_path, recursive = TRUE)
}
# ---------------------------------------------------------------------------
# 3.1  Read and plot the three non-lagged time series
# ---------------------------------------------------------------------------
box <- read.csv("data/box_data_60min.csv")
box$tdate <- as.POSIXct(box$tdate, tz = "UTC")
p_ph     <- ggplot(box, aes(tdate, Ph))     + geom_line() + labs(y = "Ph (W)",       x = NULL, title = "Heating power")
